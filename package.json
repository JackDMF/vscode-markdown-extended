{
  "name": "markdown-extended-pro",
  "displayName": "Markdown Extended Pro",
  "description": "Extended syntaxes to built-in markdown & What you see is what you get exporter.",
  "icon": "images/logo-small.png",
  "version": "3.0.0",
  "publisher": "jackdmf",
  "engines": {
    "vscode": "^1.80.0"
  },
  "license": "SEE LICENSE IN LICENSE.txt",
  "bugs": {
    "url": "https://github.com/JackDMF/vscode-markdown-extended/issues"
  },
  "homepage": "https://github.com/JackDMF/vscode-markdown-extended/blob/master/README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/JackDMF/vscode-markdown-extended.git"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./dist/extension.js",
  "browser": "./dist/extension.web.js",
  "contributes": {
    "themes": [
      {
        "label": "Markdown Extended Light",
        "uiTheme": "vs",
        "path": "./themes/markdown-extended-light.json"
      },
      {
        "label": "Markdown Extended Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/markdown-extended-dark.json"
      }
    ],
    "snippets": [
      {
        "language": "markdown",
        "path": "./snippets/markdown.code-snippets"
      }
    ],
    "grammars": [
      {
        "scopeName": "text.html.markdown.extended",
        "path": "./syntaxes/markdown-extended.tmLanguage.json",
        "injectTo": [
          "text.html.markdown"
        ]
      }
    ],
    "colors": [
      {
        "id": "markdown.sidenote.textColor",
        "description": "Color for sidenote reference text",
        "defaults": {
          "dark": "#75BFFF",
          "light": "#0066B8"
        }
      },
      {
        "id": "markdown.marginalnote.textColor",
        "description": "Color for marginal note reference text",
        "defaults": {
          "dark": "#FF7B72",
          "light": "#D73A49"
        }
      },
      {
        "id": "markdown.leftsidebar.textColor",
        "description": "Color for left sidebar text",
        "defaults": {
          "dark": "#56B6C2",
          "light": "#0B7E85"
        }
      },
      {
        "id": "markdown.rightsidebar.textColor",
        "description": "Color for right sidebar text",
        "defaults": {
          "dark": "#D2A8FF",
          "light": "#6F42C1"
        }
      }
    ],
    "commands": [
      {
        "command": "markdownExtended.export",
        "title": "%markdownExtended.exportCurrent%",
        "category": "Markdown"
      },
      {
        "command": "markdownExtended.exportWorkspace",
        "title": "%markdownExtended.exportWorkspace%",
        "category": "Markdown"
      },
      {
        "command": "markdownExtended.installBrowser",
        "title": "Install Chromium Browser for Export",
        "category": "Markdown"
      },
      {
        "command": "markdownExtended.copy",
        "title": "%markdownExtended.copy%",
        "category": "Markdown"
      },
      {
        "command": "markdownExtended.copyWithStyle",
        "title": "%markdownExtended.copyWithStyle%",
        "category": "Markdown"
      },
      {
        "command": "markdownExtended.pasteAsTable",
        "title": "%markdownExtended.pasteAsTable%",
        "category": "Markdown"
      },
      {
        "command": "markdownExtended.formateTable",
        "title": "%markdownExtended.formateTable%",
        "category": "Markdown"
      },
      {
        "command": "markdownExtended.toggleBold",
        "title": "%markdownExtended.toggleBold%",
        "category": "Markdown"
      },
      {
        "command": "markdownExtended.toggleCodeBlock",
        "title": "%markdownExtended.toggleCodeBlock%",
        "category": "Markdown"
      },
      {
        "command": "markdownExtended.toggleBlockQuote",
        "title": "%markdownExtended.toggleBlockQuote%",
        "category": "Markdown"
      },
      {
        "command": "markdownExtended.toggleCodeInline",
        "title": "%markdownExtended.toggleCodeInline%",
        "category": "Markdown"
      },
      {
        "command": "markdownExtended.toggleItalics",
        "title": "%markdownExtended.toggleItalics%",
        "category": "Markdown"
      },
      {
        "command": "markdownExtended.toggleSubscript",
        "title": "%markdownExtended.toggleSubscript%",
        "category": "Markdown"
      },
      {
        "command": "markdownExtended.toggleOList",
        "title": "%markdownExtended.toggleOList%",
        "category": "Markdown"
      },
      {
        "command": "markdownExtended.toggleStrikethrough",
        "title": "%markdownExtended.toggleStrikethrough%",
        "category": "Markdown"
      },
      {
        "command": "markdownExtended.toggleUList",
        "title": "%markdownExtended.toggleUList%",
        "category": "Markdown"
      },
      {
        "command": "markdownExtended.toggleUnderLine",
        "title": "%markdownExtended.toggleUnderLine%",
        "category": "Markdown"
      },
      {
        "command": "markdownExtended.toggleMark",
        "title": "%markdownExtended.toggleMark%",
        "category": "Markdown"
      },
      {
        "command": "markdownExtended.toggleSuperscript",
        "title": "%markdownExtended.toggleSuperscript%",
        "category": "Markdown"
      },
      {
        "command": "markdownExtended.addColumnRight",
        "title": "%markdownExtended.addColumnRight%",
        "category": "Markdown"
      },
      {
        "command": "markdownExtended.addColumnLeft",
        "title": "%markdownExtended.addColumnLeft%",
        "category": "Markdown"
      },
      {
        "command": "markdownExtended.addRowBelow",
        "title": "%markdownExtended.addRowBelow%",
        "category": "Markdown"
      },
      {
        "command": "markdownExtended.addRowAbove",
        "title": "%markdownExtended.addRowAbove%",
        "category": "Markdown"
      },
      {
        "command": "markdownExtended.DeleteColumn",
        "title": "%markdownExtended.DeleteColumn%",
        "category": "Markdown"
      },
      {
        "command": "markdownExtended.DeleteRow",
        "title": "%markdownExtended.DeleteRow%",
        "category": "Markdown"
      },
      {
        "command": "markdownExtended.MoveColumnLeft",
        "title": "%markdownExtended.MoveColumnLeft%",
        "category": "Markdown"
      },
      {
        "command": "markdownExtended.MoveColumnRight",
        "title": "%markdownExtended.MoveColumnRight%",
        "category": "Markdown"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "editorLangId == markdown && !isWeb",
          "command": "markdownExtended.export",
          "group": "markdown"
        },
        {
          "when": "editorLangId == markdown",
          "command": "markdownExtended.copy",
          "group": "markdown"
        },
        {
          "when": "editorLangId == markdown",
          "command": "markdownExtended.copyWithStyle",
          "group": "markdown"
        },
        {
          "when": "editorLangId == markdown",
          "command": "markdownExtended.pasteAsTable",
          "group": "markdown"
        },
        {
          "when": "editorLangId == markdown",
          "command": "markdownExtended.formateTable",
          "group": "markdown"
        }
      ],
      "explorer/context": [
        {
          "command": "markdownExtended.exportWorkspace",
          "when": "!isWeb",
          "group": "markdown"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "Markdown Extended Configuration",
      "properties": {
        "markdownExtended.export.theme": {
          "type": "string",
          "default": "light",
          "enum": [
            "light",
            "dark",
            "auto"
          ],
          "enumDescriptions": [
            "%markdownExtended.configuration.exportTheme.light%",
            "%markdownExtended.configuration.exportTheme.dark%",
            "%markdownExtended.configuration.exportTheme.auto%"
          ],
          "description": "%markdownExtended.configuration.exportTheme%",
          "order": 1
        },
        "markdownExtended.export.outDirName": {
          "type": "string",
          "default": "out",
          "description": "%markdownExtended.configuration.exportOutDirName%",
          "order": 2
        },
        "markdownExtended.export.puppeteerExecutable": {
          "type": "string",
          "default": "",
          "description": "%markdownExtended.configuration.puppeteerExecutable%",
          "order": 3
        },
        "markdownExtended.export.defaultStyles": {
          "type": "boolean",
          "default": true,
          "description": "%markdownExtended.configuration.exportDefaultStyles%",
          "order": 4
        },
        "markdownExtended.pdf.format": {
          "type": "string",
          "default": "A4",
          "enum": [
            "Letter",
            "Legal",
            "Tabloid",
            "Ledger",
            "A0",
            "A1",
            "A2",
            "A3",
            "A4",
            "A5",
            "A6"
          ],
          "description": "%markdownExtended.configuration.pdfFormat%",
          "order": 10
        },
        "markdownExtended.pdf.width": {
          "type": "string",
          "default": "",
          "pattern": "^$|^[0-9]+(\\.[0-9]+)?(mm|cm|in|px|pt|pc)$",
          "patternErrorMessage": "%markdownExtended.configuration.lengthError%",
          "description": "%markdownExtended.configuration.pdfWidth%",
          "order": 11
        },
        "markdownExtended.pdf.height": {
          "type": "string",
          "default": "",
          "pattern": "^$|^[0-9]+(\\.[0-9]+)?(mm|cm|in|px|pt|pc)$",
          "patternErrorMessage": "%markdownExtended.configuration.lengthError%",
          "description": "%markdownExtended.configuration.pdfHeight%",
          "order": 12
        },
        "markdownExtended.pdf.landscape": {
          "type": "boolean",
          "default": false,
          "description": "%markdownExtended.configuration.pdfLandscape%",
          "order": 13
        },
        "markdownExtended.pdf.margin.top": {
          "type": "string",
          "default": "1.5cm",
          "pattern": "^[0-9]+(\\.[0-9]+)?(mm|cm|in|px|pt|pc)$",
          "patternErrorMessage": "%markdownExtended.configuration.lengthError%",
          "description": "%markdownExtended.configuration.pdfMarginTop%",
          "order": 14
        },
        "markdownExtended.pdf.margin.right": {
          "type": "string",
          "default": "1cm",
          "pattern": "^[0-9]+(\\.[0-9]+)?(mm|cm|in|px|pt|pc)$",
          "patternErrorMessage": "%markdownExtended.configuration.lengthError%",
          "description": "%markdownExtended.configuration.pdfMarginRight%",
          "order": 15
        },
        "markdownExtended.pdf.margin.bottom": {
          "type": "string",
          "default": "1cm",
          "pattern": "^[0-9]+(\\.[0-9]+)?(mm|cm|in|px|pt|pc)$",
          "patternErrorMessage": "%markdownExtended.configuration.lengthError%",
          "description": "%markdownExtended.configuration.pdfMarginBottom%",
          "order": 16
        },
        "markdownExtended.pdf.margin.left": {
          "type": "string",
          "default": "1cm",
          "pattern": "^[0-9]+(\\.[0-9]+)?(mm|cm|in|px|pt|pc)$",
          "patternErrorMessage": "%markdownExtended.configuration.lengthError%",
          "description": "%markdownExtended.configuration.pdfMarginLeft%",
          "order": 17
        },
        "markdownExtended.pdf.displayHeaderFooter": {
          "type": "boolean",
          "default": true,
          "description": "%markdownExtended.configuration.pdfDisplayHeaderFooter%",
          "order": 18
        },
        "markdownExtended.pdf.pageRanges": {
          "type": "string",
          "default": "",
          "description": "%markdownExtended.configuration.pdfPageRanges%",
          "order": 19
        },
        "markdownExtended.pdf.headerTemplate": {
          "type": "string",
          "default": "<div style=\"font-size: 9px; margin-left: 1cm;\"> <span class='title'></span></div> <div style=\"font-size: 9px; margin-left: auto; margin-right: 1cm; \"> <span class='date'></span></div>",
          "description": "%markdownExtended.configuration.pdfHeaderTemplate%",
          "order": 20
        },
        "markdownExtended.pdf.footerTemplate": {
          "type": "string",
          "default": "<div style=\"font-size: 9px; margin: 0 auto;\"> <span class='pageNumber'></span> / <span class='totalPages'></span></div>",
          "description": "%markdownExtended.configuration.pdfFooterTemplate%",
          "order": 21
        },
        "markdownExtended.image.quality": {
          "type": "integer",
          "default": 100,
          "minimum": 0,
          "maximum": 100,
          "description": "%markdownExtended.configuration.imageQuality%",
          "order": 30
        },
        "markdownExtended.image.omitBackground": {
          "type": "boolean",
          "default": false,
          "description": "%markdownExtended.configuration.imageOmitBackground%",
          "order": 31
        },
        "markdownExtended.plugins.disabled": {
          "type": "string",
          "default": "",
          "description": "%markdownExtended.configuration.disabledPlugins%",
          "order": 40
        },
        "markdownExtended.toc.levels": {
          "type": "array",
          "default": [
            1,
            2,
            3
          ],
          "description": "%markdownExtended.configuration.tocLevels%",
          "order": 41
        },
        "markdownExtended.exportTheme": {
          "type": "string",
          "default": "light",
          "deprecationMessage": "%markdownExtended.configuration.deprecated%"
        },
        "markdownExtended.exportOutDirName": {
          "type": "string",
          "default": "out",
          "deprecationMessage": "%markdownExtended.configuration.deprecated%"
        },
        "markdownExtended.puppeteerExecutable": {
          "type": "string",
          "default": "",
          "deprecationMessage": "%markdownExtended.configuration.deprecated%"
        },
        "markdownExtended.pdfFormat": {
          "type": "string",
          "default": "A4",
          "deprecationMessage": "%markdownExtended.configuration.deprecated%"
        },
        "markdownExtended.pdfWidth": {
          "type": "string",
          "default": "",
          "deprecationMessage": "%markdownExtended.configuration.deprecated%"
        },
        "markdownExtended.pdfHeight": {
          "type": "string",
          "default": "",
          "deprecationMessage": "%markdownExtended.configuration.deprecated%"
        },
        "markdownExtended.pdfLandscape": {
          "type": "boolean",
          "default": false,
          "deprecationMessage": "%markdownExtended.configuration.deprecated%"
        },
        "markdownExtended.pdfMarginTop": {
          "type": "string",
          "default": "1.5cm",
          "deprecationMessage": "%markdownExtended.configuration.deprecated%"
        },
        "markdownExtended.pdfMarginRight": {
          "type": "string",
          "default": "1cm",
          "deprecationMessage": "%markdownExtended.configuration.deprecated%"
        },
        "markdownExtended.pdfMarginBottom": {
          "type": "string",
          "default": "1cm",
          "deprecationMessage": "%markdownExtended.configuration.deprecated%"
        },
        "markdownExtended.pdfMarginLeft": {
          "type": "string",
          "default": "1cm",
          "deprecationMessage": "%markdownExtended.configuration.deprecated%"
        },
        "markdownExtended.pdfDisplayHeaderFooter": {
          "type": "boolean",
          "default": true,
          "deprecationMessage": "%markdownExtended.configuration.deprecated%"
        },
        "markdownExtended.pdfPageRanges": {
          "type": "string",
          "default": "",
          "deprecationMessage": "%markdownExtended.configuration.deprecated%"
        },
        "markdownExtended.pdfHeaderTemplate": {
          "type": "string",
          "default": "",
          "deprecationMessage": "%markdownExtended.configuration.deprecated%"
        },
        "markdownExtended.pdfFooterTemplate": {
          "type": "string",
          "default": "",
          "deprecationMessage": "%markdownExtended.configuration.deprecated%"
        },
        "markdownExtended.imageQuality": {
          "type": "integer",
          "default": 100,
          "deprecationMessage": "%markdownExtended.configuration.deprecated%"
        },
        "markdownExtended.imageOmitBackground": {
          "type": "boolean",
          "default": false,
          "deprecationMessage": "%markdownExtended.configuration.deprecated%"
        },
        "markdownExtended.disabledPlugins": {
          "type": "string",
          "default": "",
          "deprecationMessage": "%markdownExtended.configuration.deprecated%"
        },
        "markdownExtended.tocLevels": {
          "type": "array",
          "default": [
            1,
            2,
            3
          ],
          "deprecationMessage": "%markdownExtended.configuration.deprecated%"
        }
      }
    },
    "walkthroughs": [
      {
        "id": "markdownExtendedGettingStarted",
        "title": "Get Started with Markdown Extended",
        "description": "Learn the extended Markdown syntax and export to HTML, PDF, or images.",
        "steps": [
          {
            "id": "mdext.welcome",
            "title": "Welcome",
            "description": "What Markdown Extended Pro adds, and how to preview it live.\n[Open Preview to the Side](command:markdown.showPreviewToSide)",
            "media": {
              "markdown": "media/walkthrough/welcome.md"
            }
          },
          {
            "id": "mdext.annotations",
            "title": "Sidenotes & annotations",
            "description": "The signature feature — floating sidenotes, marginal notes, and sidebars, with Markdown inside the note.\n[New Markdown file](command:workbench.action.files.newUntitledFile?%7B%22languageId%22%3A%22markdown%22%7D)",
            "media": {
              "markdown": "media/walkthrough/annotations.md"
            }
          },
          {
            "id": "mdext.syntax",
            "title": "Extended syntax",
            "description": "Admonitions, containers, marks, footnotes, TOC, attributes, and more.",
            "media": {
              "markdown": "media/walkthrough/syntax.md"
            }
          },
          {
            "id": "mdext.editing",
            "title": "Editing helpers & tables",
            "description": "Toggle formatting, build and reshape tables, and paste CSV straight in as a Markdown table.\n[Paste as Markdown Table](command:markdownExtended.pasteAsTable)",
            "media": {
              "image": "images/pasteTable.gif",
              "altText": "Pasting CSV data as a formatted Markdown table"
            }
          },
          {
            "id": "mdext.export",
            "title": "Export anywhere",
            "description": "Self-contained HTML, PDF, PNG, or JPEG — then Open or Reveal the result.\n[Run Export](command:markdownExtended.export)",
            "media": {
              "markdown": "media/walkthrough/export.md"
            },
            "completionEvents": [
              "onCommand:markdownExtended.export"
            ]
          },
          {
            "id": "mdext.theme",
            "title": "Themes & styling",
            "description": "Light/dark/auto export, a built-in accessible stylesheet, your own CSS, and editor color themes.\n[Open settings](command:workbench.action.openSettings?%22markdownExtended%22)",
            "media": {
              "markdown": "media/walkthrough/theme.md"
            }
          }
        ]
      }
    ],
    "markdown.markdownItPlugins": true,
    "markdown.previewStyles": [
      "styles/markdown-it-admonition.css",
      "styles/markdown-it-kbd.css"
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "analyze": "node esbuild.js --analyze",
    "compile-tests": "tsc -p ./",
    "watch-tests": "tsc -watch -p ./",
    "pretest": "npm run compile-tests",
    "test": "npm run compile-tests && node ./out/test/index.js",
    "test:unit": "npm run compile-tests && node ./out/test/runTest.js",
    "lint": "eslint src --ext ts",
    "lint:fix": "eslint src --ext ts --fix"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^22.13.9",
    "@types/sinon": "^17.0.4",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.0",
    "esbuild-visualizer": "^0.7.0",
    "eslint": "^9.39.1",
    "glob": "^11.0.3",
    "mocha": "^11.7.5",
    "path-browserify": "^1.0.1",
    "sinon": "^21.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.3"
  },
  "dependencies": {
    "@puppeteer/browsers": "^2.10.13",
    "highlight.js": "^11.9.0",
    "js-yaml": "^4.1.0",
    "markdown-it-abbr": "^2.0.0",
    "markdown-it-attrs": "^4.1.6",
    "markdown-it-bracketed-spans": "^1.0.1",
    "markdown-it-checkbox": "^1.1.0",
    "markdown-it-cjk-friendly": "^2.0.2",
    "markdown-it-container": "^4.0.0",
    "markdown-it-deflist": "^3.0.0",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-html5-embed": "^0.3.3",
    "markdown-it-ib": "^2.0.0",
    "markdown-it-kbd": "^2.2.2",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-multimd-table": "^4.2.3",
    "markdown-it-sub-alt": "^1.0.0",
    "markdown-it-sup-alt": "^1.0.2",
    "markdown-it-table-of-contents": "^0.9.0",
    "mermaid": "^11.16.0",
    "papaparse": "^5.4.1",
    "puppeteer": "^24.3.1"
  }
}
